# ClinIQ-Nexus Local Development (reference)
# Copy to .env and override for your environment.
# WARNING: These defaults are ONLY for local demo. Rotate all secrets before any shared/stage/prod use.
# Production: inject via Secrets Manager / k8s secrets / vault. Never commit real values.

DATABASE_URL=postgresql+asyncpg://cliniq:cliniq_dev_password@localhost:5432/cliniq_nexus
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
USE_REAL_AWS=false
JWT_SECRET=dev-jwt-secret-change-in-prod-please
DEFAULT_TENANT_ID=tenant_hospital_a

# Hardening / reliability (new)
MAX_REQUEST_BYTES=10485760
REQUEST_TIMEOUT_SECONDS=45

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCK_AUTH=true

# Optional for compose: POSTGRES_PASSWORD=... (falls back to dev value)
