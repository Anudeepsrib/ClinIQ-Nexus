# MediCore AI Platform - Frontend Environment
# Copy this file to .env.local and fill in real values for production.

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-32-char-random-secret

# AWS Cognito (used by NextAuth CognitoProvider)
COGNITO_CLIENT_ID=your-cognito-app-client-id
COGNITO_CLIENT_SECRET=your-cognito-app-client-secret
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
