# MediCore AI Platform - Frontend Environment
# Copy this file to .env.local (or set via your platform)

# -----------------------------------------------------------------------------
# NextAuth.js + Cognito (Production SSO)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-32-char-random-secret-for-production

# AWS Cognito (NextAuth CognitoProvider)
COGNITO_CLIENT_ID=your-cognito-app-client-id
COGNITO_CLIENT_SECRET=your-cognito-app-client-secret
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX

# -----------------------------------------------------------------------------
# Backend API (Critical)
# -----------------------------------------------------------------------------
# All API calls go through this base URL.
# In Docker Compose this is usually http://platform-api:8000 from inside the network,
# or http://localhost:8000 when running the frontend standalone.
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Production Notes
# - Set NEXTAUTH_SECRET via a secure secret manager
# - Use HTTPS for NEXTAUTH_URL and NEXT_PUBLIC_API_URL in prod
# - Tighten the CSP in next.config.mjs for your actual domains
# - Consider adding Sentry DSN here for frontend error reporting
# -----------------------------------------------------------------------------
